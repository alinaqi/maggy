#!/bin/bash
# Stop hook — asks qwen3 whether current state warrants a multi-model review.
# No hardcoded thresholds — the smallest available model decides dynamically.
# No set -euo pipefail: hook scripts must be defensive.

INPUT=$(cat 2>/dev/null || true)
CWD=$(echo "$INPUT" | jq -r '.cwd // empty' 2>/dev/null || echo ".")

cd "$CWD" 2>/dev/null || exit 0

TURN_COUNT=$(echo "$INPUT" | jq -r '.turn_count // 0' 2>/dev/null || echo "0")

REVIEW_STATE="$HOME/.claude/auto-review-state.json"
LAST_REVIEW_TURN=$(cat "$REVIEW_STATE" 2>/dev/null | jq -r '.last_turn // 0' 2>/dev/null || echo "0")
TURNS_SINCE=$((TURN_COUNT - LAST_REVIEW_TURN))
LAST_CHECK_TURN=$(cat "$REVIEW_STATE" 2>/dev/null | jq -r '.last_check // 0' 2>/dev/null || echo "0")
CHECKS_SINCE=$((TURN_COUNT - LAST_CHECK_TURN))

# Cooldown: don't even check more than every 5 turns
if [ "$CHECKS_SINCE" -lt 5 ] 2>/dev/null; then
  exit 0
fi

# Update last check time
TMP_STATE=$(mktemp)
cat "$REVIEW_STATE" 2>/dev/null | jq --arg t "$TURN_COUNT" '. + {last_check: ($t | tonumber)}' > "$TMP_STATE" 2>/dev/null && mv "$TMP_STATE" "$REVIEW_STATE" 2>/dev/null || true
rm -f "$TMP_STATE"

# Minimum 10 turns between reviews
if [ "$TURNS_SINCE" -lt 10 ] 2>/dev/null; then
  exit 0
fi

# ── Build context for qwen3 to decide ────────────────────────────────────
GIT_DIFF_STAT=$(git diff --stat HEAD 2>/dev/null | tail -10 || echo "no changes")
FILES_CHANGED=$(echo "$GIT_DIFF_STAT" | wc -l | tr -d ' ')
SECURITY_PATHS=$(git diff --name-only HEAD 2>/dev/null | grep -iE '(auth|security|crypto|token|password|secret|encrypt)' || echo "none")
BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")

CLASSIFY_PROMPT="You are a review gatekeeper. Based on the following state, decide if this work warrants a multi-model code review. A review is warranted when: significant implementation is done (not just planning), multiple files changed, security-sensitive code touched, or the session has been working for a while without review. A review is NOT warranted for: small fixes, research, planning/discussion, single-file trivial changes, or documentation-only updates.

State:
- Branch: ${BRANCH}
- Turn count: ${TURN_COUNT}
- Turns since last review: ${TURNS_SINCE}
- Files changed: ${FILES_CHANGED}
- Security paths touched: ${SECURITY_PATHS}
- Git diff stat: ${GIT_DIFF_STAT}

Reply with exactly one word: REVIEW_NEEDED or NO_REVIEW. Then a colon and a one-sentence reason."

# ── Ask qwen3 to decide ──────────────────────────────────────────────────
if curl -s --connect-timeout 2 http://localhost:11434/api/tags >/dev/null 2>&1; then
  CONTENT=$(echo "$CLASSIFY_PROMPT" | jq -Rs .)
  DECISION=$(curl -s --max-time 8 http://localhost:11434/api/chat \
    -d "{\"model\": \"qwen3-coder:30b-a3b-q8_0\", \"messages\": [{\"role\": \"user\", \"content\": ${CONTENT}}], \"stream\": false, \"options\": {\"temperature\": 0.1, \"num_predict\": 30}}" \
    2>/dev/null | jq -r '.message.content // ""' | head -1 || true)
else
  # Ollama down — skip this check, will retry next time
  exit 0
fi

if echo "$DECISION" | grep -qi "REVIEW_NEEDED"; then
  REASON=$(echo "$DECISION" | sed 's/^[^:]*:\s*//')
  echo "[auto-review] qwen3: REVIEW_NEEDED — $REASON (turn $TURN_COUNT)" >&2

  REVIEW_BIN="$HOME/bin/review"
  if [ -x "$REVIEW_BIN" ]; then
    nohup "$REVIEW_BIN" --deepseek --kimi "Review the recent changes in $CWD (branch: $BRANCH). Context: $GIT_DIFF_STAT. Reason qwen3 flagged for review: $REASON" \
      > "$HOME/.claude/last-review.txt" 2>&1 &
    echo "{\"last_turn\": $TURN_COUNT, \"last_check\": $TURN_COUNT, \"ts\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\", \"reason\": $(echo "$REASON" | jq -Rs .), \"classifier\": \"qwen3\"}" > "$REVIEW_STATE"
  fi
else
  echo "[auto-review] qwen3: NO_REVIEW (turn $TURN_COUNT)" >&2
fi

exit 0
